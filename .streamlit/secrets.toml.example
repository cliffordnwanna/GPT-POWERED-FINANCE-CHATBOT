# .streamlit/secrets.toml — LOCAL DEVELOPMENT ONLY.
#
# Copy this file to .streamlit/secrets.toml and fill in your values.
# This file is used when running locally instead of a .env file.
# NEVER commit secrets.toml — it is excluded by .gitignore.
#
# When deployed on Streamlit Community Cloud, add these same key-value
# pairs via the app dashboard: Settings → Secrets.

OPENAI_API_KEY = "sk-your-key-here"
MODEL_NAME = "gpt-4o-mini"
USE_AZURE = "false"
MAX_HISTORY_TURNS = "5"
MAX_TOKENS = "500"
MAX_INPUT_LENGTH = "500"
MAX_REQUESTS_PER_SESSION = "20"
LOG_LEVEL = "INFO"
